{
  "headers": [
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "redirects": [
    { "source": "/contact", "destination": "/appointment", "permanent": true },
    { "source": "/home", "destination": "/", "permanent": true },
    { "source": "/health-articles", "destination": "/blog", "permanent": true }
  ]
}
